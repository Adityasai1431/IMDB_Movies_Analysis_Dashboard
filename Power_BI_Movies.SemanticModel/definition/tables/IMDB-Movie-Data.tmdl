table IMDB-Movie-Data
	lineageTag: da59ae7a-eaef-4ea3-9bc4-7324a9457ea5

	measure 'Total Movies' = DISTINCTCOUNT('IMDB-Movie-Data'[Rank])
		formatString: 0
		lineageTag: ad2e4e46-8cb7-496c-bebe-d4a17017927b

	measure 'Genres Count' = DISTINCTCOUNT('IMDB-Movie-Data'[Genre])
		formatString: 0
		lineageTag: 5b97472b-f43c-4d8c-9294-56d00bb99a72

	measure 'Average Rating' = AVERAGE('IMDB-Movie-Data'[Rating])
		lineageTag: 674a508d-0507-462f-a230-ba621157c84b

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Highest Rated Genre' =
			
			TOPN(1,
			    ALL('IMDB-Movie-Data'[Genre]),
			    [Average Rating],
			    DESC
			)
		lineageTag: 5d1fefa0-0e67-4d96-a27d-63dac5e750a4

	measure 'Common Genre' = ```
			
			TOPN(
			    1,
			    ALL('IMDB-Movie-Data'[Genre]),
			    [Total Movies],
			    DESC
			)
			
			```
		lineageTag: 7ff81ae6-0d86-4b5e-b6fc-818ceb322abf

